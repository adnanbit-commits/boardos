// BoardOS — Prisma Schema
// Modular multi-tenant governance platform
// Each governance table carries company_id for tenant isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  DIRECTOR          // Board member — votes, signs resolutions
  COMPANY_SECRETARY // Appointed CS — records minutes, compliance
  AUDITOR           // Statutory CA — read + audit actions only
  OBSERVER          // Read-only — investor, advisor, silent partner
}

enum DesignationEnum {
  // Director designations
  EXECUTIVE_DIRECTOR
  NON_EXECUTIVE_DIRECTOR
  INDEPENDENT_DIRECTOR
  NOMINEE_DIRECTOR
  MANAGING_DIRECTOR
  DIRECTOR_SIMPLICITOR   // CA who is also a director (non-voting on audit matters)
  // CS designations
  WHOLE_TIME_CS
  CS_IN_PRACTICE
  CS_AS_KMP
  // Auditor designations
  STATUTORY_AUDITOR
  INTERNAL_AUDITOR
  COST_AUDITOR
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  VOTING
  MINUTES_DRAFT
  MINUTES_CIRCULATED  // Draft circulated to directors for 7-day comment window (SS-1)
  SIGNED
  LOCKED
}

enum ResolutionStatus {
  DRAFT
  PROPOSED
  VOTING
  APPROVED
  REJECTED
  NOTED     // For NOTING-type only — placed on record
}

enum ResolutionType {
  MEETING
  CIRCULAR
  NOTING    // Board takes document/declaration on record — no vote
}

enum CircularSignatureValue {
  FOR
  OBJECT
}

enum VoteValue {
  APPROVE
  REJECT
  ABSTAIN
}

enum MinutesStatus {
  DRAFT
  SIGNED
  LOCKED
}

enum AttendanceMode {
  IN_PERSON
  VIDEO
  PHONE
  ABSENT
  REQUESTED_VIDEO   // pending — awaiting chairperson/CS confirmation
  REQUESTED_PHONE   // pending — awaiting chairperson/CS confirmation
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  MEETING_INVITE
  VOTE_REQUEST
  SIGNATURE_REQUEST
  MINUTES_READY
  GENERAL
}


// ── Document Vault enums ──────────────────────────────────────────────────────

enum VaultDocType {
  INCORPORATION_CERT
  MOA
  AOA
  PAN
  GST_CERT
  COMMON_SEAL
  CUSTOM
}

enum ComplianceForm {
  DIR_2       // Consent to act as director — on appointment
  MBP_1       // Disclosure of interest — annually + on change
  DIR_8       // Non-disqualification declaration — annually
  DIR_3_KYC   // Annual KYC — by Sep 30 each year
  CUSTOM
}

enum MeetingDocType {
  DRAFT_NOTICE
  DRAFT_AGENDA
  SUPPORTING_PAPER
  DRAFT_RESOLUTION
  CUSTOM
}

enum DocNoteStatus {
  NOTED                // Chair confirmed receipt with no issues
  NOTED_WITH_EXCEPTION // Chair noted but flagged an issue
  PHYSICALLY_PRESENT   // Doc not uploaded but chairperson confirms physical presence at deemed venue
}

// ── DeclarationFormType (existing, keep here) ─────────────────────────────────

enum DeclarationFormType {
  DIR_2   // Consent to act as director — Sec. 152(5)
  DIR_8   // Non-disqualification declaration — Sec. 164(2)
  MBP_1   // Disclosure of interest — Sec. 184(1)
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash    String?
  googleId        String?  @unique
  onboardingDone  Boolean  @default(false)
  platformRoles   String[] @default([]) @map("platform_roles")
  userIntent      String?  // legacy — kept for migration safety
  phone         String?
  avatarUrl     String?
  isActive            Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  companyUsers        CompanyUser[]
  votes               Vote[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  signedMinutes       Minutes[]              @relation("SignedBy")
  sentInvites         Invitation[]           @relation("SentInvites")
  attendance          MeetingAttendance[]
  circularSignatures  CircularSignature[]
  declarations        DirectorDeclaration[]
  vaultUploads        VaultDocument[]        @relation("VaultUploads")
  complianceDocs      DirectorComplianceDoc[] @relation("DirectorComplianceDocs")
  meetingDocUploads   MeetingDocument[]      @relation("MeetingDocUploads")
  shareLinkCreated    MeetingShareLink[]     @relation("ShareLinkCreators")
  directorNotes       MeetingDocNote[]       @relation("DirectorNotes")
  rollCalls           MeetingRollCall[]
  chairNotes          MeetingDocNote[]       @relation("ChairNotes")

  @@map("users")
}

// ─────────────────────────────────────────────
// COMPANIES (multi-tenant root)
// ─────────────────────────────────────────────

model Company {
  id            String   @id @default(uuid())
  name          String
  cin           String?  @unique  // Company Identification Number
  pan           String?
  registeredAt  String?           // e.g. "Mumbai, MH"
  logoUrl       String?
  isActive            Boolean  @default(true)
  minutesCustodianId          String?  // Director authorised to keep statutory registers (Rule 25(1)(f))
  firstBoardMeetingLockedId   String?  // meetingId of locked first meeting — suppresses first-meeting-only template items
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  companyUsers      CompanyUser[]
  meetings          Meeting[]
  meetingTemplates  MeetingTemplate[]
  resolutions       Resolution[]
  documents         Document[]
  vaultDocuments    VaultDocument[]
  complianceDocs    DirectorComplianceDoc[]
  meetingDocuments  MeetingDocument[]
  docNotes          MeetingDocNote[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  archivedDocs      ArchivedDocument[]
  invitations       Invitation[]

  @@map("companies")
}

// Junction: user ↔ company with role
model CompanyUser {
  id         String   @id @default(uuid())
  userId     String
  companyId  String
  role       UserRole @default(DIRECTOR)

  // Platform-level workspace management — invisible in legal docs/minutes
  isWorkspaceAdmin     Boolean        @default(false) @map("is_workspace_admin")

  // Additional designation — sub-category shown in minutes and documents
  additionalDesignation DesignationEnum? @map("additional_designation")
  designationLabel      String?          @map("designation_label")

  invitedAt  DateTime @default(now())
  acceptedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("company_users")
}

// Token-based invite — exists until accepted or expired
// Allows inviting people who aren't registered yet
model Invitation {
  id          String    @id @default(uuid())
  companyId   String
  email       String                      // Invitee email
  role        UserRole  @default(DIRECTOR)
  token       String    @unique           // Secure random token (32 bytes hex)
  invitedById String                      // Who sent the invite
  acceptedAt  DateTime?
  expiresAt   DateTime                    // 7-day TTL
  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("SentInvites", fields: [invitedById], references: [id])

  @@unique([companyId, email])            // One pending invite per email per company
  @@map("invitations")
}

// ─────────────────────────────────────────────
// MEETINGS
// ─────────────────────────────────────────────

model Meeting {
  id            String        @id @default(uuid())
  companyId     String
  title         String
  description   String?
  scheduledAt   DateTime
  location      String?
  status        MeetingStatus @default(DRAFT)

  // Video integration
  videoProvider String?       // "zoom" | "meet" | "teams"
  videoUrl      String?
  videoMeetingId String?

  chairpersonId    String?       // Director elected as chairperson for this specific meeting
  minutesRecorderId String?      // Director authorised to record proceedings for this meeting (SS-1)
  minutesCirculatedAt   DateTime?   // When draft minutes were circulated to directors

  // First meeting + virtual meeting fields
  isFirstMeeting          Boolean   @default(false)  // flags first board meeting post-incorporation
  deemedVenue             String?   // SS-1: venue for virtual meetings (usually registered office)
  noticeSentAt            DateTime? // when notice was dispatched
  noticeAcknowledgedBy    String[]  @default([]) @map("notice_acknowledged_by")
  rollCallCompletedAt     DateTime?
  quorumConfirmedAt       DateTime?
  quorumConfirmedBy       String?   // userId of chairperson who confirmed quorum

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id])
  agendaItems   AgendaItem[]
  resolutions   Resolution[]
  minutes       Minutes?
  attendance    MeetingAttendance[]
  declarations  DirectorDeclaration[]
  documents     MeetingDocument[]
  shareLink     MeetingShareLink?
  docNotes      MeetingDocNote[]
  rollCalls     MeetingRollCall[]

  @@map("meetings")
}

model MeetingAttendance {
  id             String         @id @default(uuid())
  meetingId      String
  userId         String
  mode           AttendanceMode @default(IN_PERSON)
  recordedAt     DateTime       @default(now())
  // SS-1 Rule 3(4): virtual attendance confirmation fields
  location       String?        // city/address director is attending from
  noThirdParty   Boolean?       // confirmed no third party present at their location

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_attendance")
}


model DirectorDeclaration {
  id         String              @id @default(uuid())
  meetingId  String
  userId     String
  formType   DeclarationFormType
  received   Boolean             @default(false)
  notes      String?             // Interests disclosed (MBP-1), remarks
  recordedAt DateTime            @default(now())

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId, formType])
  @@map("director_declarations")
}

model AgendaItem {
  id          String   @id @default(uuid())
  meetingId   String
  title       String
  description String?
  order       Int      @default(0)
  isAob       Boolean  @default(false)  // Added after meeting started — Any Other Business (SS-1 Clause 6)

  // Typed items drive specialised UI — STANDARD works as before
  // Values: STANDARD | ROLL_CALL | QUORUM_CONFIRMATION | CHAIRPERSON_ELECTION |
  //         COMPLIANCE_NOTING | VAULT_DOC_NOTING | ELECTRONIC_CONSENT
  itemType     String   @default("STANDARD") @map("item_type")
  legalBasis   String?  @map("legal_basis")    // shown to CS, never in minutes
  guidanceNote String?  @map("guidance_note")  // shown to CS, never in minutes

  createdAt   DateTime @default(now())

  meeting     Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  resolutions Resolution[]

  @@map("agenda_items")
}

// ─────────────────────────────────────────────
// RESOLUTIONS & VOTING
// ─────────────────────────────────────────────

model Resolution {
  id           String           @id @default(uuid())
  companyId    String
  type         ResolutionType   @default(MEETING)
  meetingId    String?          // null for CIRCULAR resolutions
  deadline     DateTime?        // CIRCULAR only
  circulationNote String?       // covering note sent to directors
  serialNumber String?          // e.g. CR/2026/001 — assigned on circulate
  notedAtMeetingId String?      // Sec. 175(2) — noted at subsequent board meeting
  agendaItemId String?
  vaultDocId   String?  // exhibit: vault document linked to this NOTING resolution
  meetingDocId String?  // exhibit: meeting document linked to this NOTING resolution
  title        String
  text         String           // Full legal resolution text
  status       ResolutionStatus @default(DRAFT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company      Company          @relation(fields: [companyId], references: [id])
  meeting      Meeting?         @relation(fields: [meetingId], references: [id])
  agendaItem   AgendaItem?      @relation(fields: [agendaItemId], references: [id])
  vaultDoc     VaultDocument?   @relation(fields: [vaultDocId],   references: [id])
  meetingDoc   MeetingDocument? @relation(fields: [meetingDocId], references: [id])
  votes        Vote[]
  certifiedCopies CertifiedCopy[]
  signatures   CircularSignature[]

  @@map("resolutions")
}

model Vote {
  id           String    @id @default(uuid())
  resolutionId String
  userId       String
  value        VoteValue
  remarks      String?
  createdAt    DateTime  @default(now())

  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  // A director votes only once per resolution
  @@unique([resolutionId, userId])
  @@map("votes")
}

// ─────────────────────────────────────────────
// MINUTES
// ─────────────────────────────────────────────

model Minutes {
  id          String        @id @default(uuid())
  meetingId   String        @unique
  content     String        // HTML or structured JSON
  status      MinutesStatus @default(DRAFT)
  signedById  String?
  signedAt    DateTime?
  signatureHash String?     // Hash of signed content for tamper detection

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  meeting     Meeting       @relation(fields: [meetingId], references: [id])
  signedBy    User?         @relation("SignedBy", fields: [signedById], references: [id])
  document    Document?

  @@map("minutes")
}

// ─────────────────────────────────────────────
// DOCUMENTS & CERTIFIED COPIES
// ─────────────────────────────────────────────

model Document {
  id          String   @id @default(uuid())
  companyId   String
  minutesId   String?  @unique
  name        String
  type        String   // "minutes" | "certified_copy" | "notice" | "upload"
  s3Key       String
  s3Url       String
  mimeType    String   @default("application/pdf")
  sizeBytes   Int?
  hash        String?  // SHA-256 for integrity verification
  isImmutable Boolean  @default(false)
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id])
  minutes     Minutes? @relation(fields: [minutesId], references: [id])

  @@map("documents")
}

model CertifiedCopy {
  id            String   @id @default(uuid())
  resolutionId  String
  documentUrl   String
  s3Key         String
  signatureHash String   // Cryptographic proof of authenticity
  certifiedAt   DateTime @default(now())

  resolution    Resolution @relation(fields: [resolutionId], references: [id])

  @@map("certified_copies")
}

// ─────────────────────────────────────────────
// ARCHIVE
// ─────────────────────────────────────────────

model ArchivedDocument {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  s3Key       String
  s3Url       String
  hash        String   // SHA-256 — immutable verification
  version     Int      @default(1)
  uploadedAt  DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id])

  @@map("archived_documents")
}

// ─────────────────────────────────────────────
// AUDIT LOG (append-only, never deleted)
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String   // e.g. "VOTE_CAST", "MINUTES_SIGNED"
  entity     String   // e.g. "Resolution", "Meeting"
  entityId   String?
  metadata   Json?    // Additional context
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company    Company? @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id         String             @id @default(uuid())
  companyId  String?
  userId     String
  type       NotificationType
  subject    String
  body       String
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  createdAt  DateTime           @default(now())

  company    Company?           @relation(fields: [companyId], references: [id])
  user       User               @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model MeetingTemplate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  category    String   @default("BOARD")
  agendaItems Json     // [{title: string, description: string, order: number}]
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("meeting_templates")
}

model CircularSignature {
  id           String                 @id @default(uuid())
  resolutionId String
  userId       String
  value        CircularSignatureValue // FOR | OBJECT
  remarks      String?
  signedAt     DateTime               @default(now())

  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@unique([resolutionId, userId]) // one signature per director per resolution
  @@map("circular_signatures")
}

// ─────────────────────────────────────────────
// DOCUMENT VAULT
// ─────────────────────────────────────────────

// Company-level statutory documents — one designated slot per type
model VaultDocument {
  id          String       @id @default(uuid())
  companyId   String
  docType     VaultDocType
  label       String       // human label — for CUSTOM, user-supplied
  fileUrl     String       // GCS object path
  fileName    String
  fileSize    Int?
  uploadedAt  DateTime     @default(now())
  uploadedBy  String

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploader   User    @relation("VaultUploads", fields: [uploadedBy], references: [id])

  // Only one document per slot per company (CUSTOM can have multiples)
  resolutions Resolution[]

  @@unique([companyId, docType, label])
  @@map("vault_documents")
}

// Director compliance forms — per director, per form type, per financial year
model DirectorComplianceDoc {
  id             String         @id @default(uuid())
  companyId      String
  userId         String         // the director this form belongs to
  formType       ComplianceForm
  label          String?        // for CUSTOM type
  financialYear  String         // "2024-25"
  fileUrl        String?        // GCS path — null if not yet uploaded
  fileName       String?
  fileSize       Int?
  submittedAt    DateTime?      // when director uploaded / submitted
  receivedAt     DateTime?      // when CS physically received the paper copy
  notes          String?
  recordedBy     String?        // userId of CS or admin who last updated

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  director   User    @relation("DirectorComplianceDocs", fields: [userId], references: [id])

  @@unique([companyId, userId, formType, financialYear])
  @@map("director_compliance_docs")
}

// Documents attached to a specific meeting — pre-meeting papers
model MeetingDocument {
  id         String         @id @default(uuid())
  meetingId  String
  companyId  String
  title      String
  docType    MeetingDocType
  fileUrl    String         // GCS path
  fileName   String
  fileSize   Int?
  isShared   Boolean        @default(false) // included in public share link
  uploadedAt DateTime       @default(now())
  uploadedBy String

  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id])
  uploader  User    @relation("MeetingDocUploads", fields: [uploadedBy], references: [id])

  resolutions Resolution[]

  @@map("meeting_documents")
}

// Public share link for meeting papers
model MeetingShareLink {
  id          String   @id @default(uuid())
  meetingId   String   @unique
  shareToken  String   @unique @default(uuid())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  createdBy   String

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  creator    User    @relation("ShareLinkCreators", fields: [createdBy], references: [id])

  @@map("meeting_share_links")
}

// Chairperson's formal noting of compliance documents at meeting
// One record per director per form type per meeting
model MeetingDocNote {
  id             String        @id @default(uuid())
  meetingId      String
  companyId      String
  directorUserId String        // whose document is being noted
  formType       ComplianceForm
  status         DocNoteStatus
  exception      String?       // free text when NOTED_WITH_EXCEPTION
  notedBy        String        // chairperson userId
  notedAt        DateTime      @default(now())

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  company    Company @relation(fields: [companyId], references: [id])
  director   User    @relation("DirectorNotes", fields: [directorUserId], references: [id])
  chair      User    @relation("ChairNotes", fields: [notedBy], references: [id])

  @@unique([meetingId, directorUserId, formType])
  @@map("meeting_doc_notes")
}

// ─────────────────────────────────────────────
// MEETING ROLL CALL
// ─────────────────────────────────────────────

// Per-director roll call response at meeting opening.
// Required by SS-1 Rule 3(4) for video conferencing — every director
// must confirm their location and that no third party is present.
// Recorded in minutes automatically.

model MeetingRollCall {
  id                 String   @id @default(uuid())
  meetingId          String
  userId             String
  location           String   // city/address director is attending from
  noThirdParty       Boolean  @default(false) // confirmed no one else present
  materialsReceived  Boolean  @default(false) // confirmed receipt of notice + agenda
  respondedAt        DateTime @default(now())

  meeting  Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId],    references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_roll_calls")
}
