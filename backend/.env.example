# BoardOS Backend — Environment Variables
# Copy to .env for local dev: cp .env.example .env

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://boardos:boardos@localhost:5432/boardos?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=boardos-dev-secret-change-in-productionchange-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=boardos-documents-dev 

# ── Email (Nodemailer / SES) ───────────────────────────────────────────────────
SMTP_HOST=smtp.ses.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@boardos.in

# ── App ────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
PORT=3001
NODE_ENV=development

# ── Puppeteer ─────────────────────────────────────────────────────────────────
# Set to 'true' in Docker to disable sandbox (required in containers)
PUPPETEER_NO_SANDBOX=false
