# BoardOS Frontend — copy to .env.local for local dev
# cp .env.example .env.local

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to show the Partner Dashboard link in the sidebar
NEXT_PUBLIC_PARTNER_DASHBOARD_ENABLED=false

# PostHog analytics (optional — leave blank to disable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
